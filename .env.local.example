# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# MongoDB connection. A local `mongod` on the default port works for dev.
# Use 127.0.0.1 rather than localhost — on some Windows setups MongoDB only
# binds IPv4 and Node resolves "localhost" to the IPv6 ::1 first, causing
# ECONNREFUSED.
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=bulletproof_cop

# Secret used to sign session JWTs — use a long random string in production
# (e.g. `openssl rand -base64 32`).
JWT_SECRET=dev-only-insecure-secret-change-me

# Optional: Resend (https://resend.com) — used to send password-reset emails.
# If unset, forgot-password falls back to returning the reset token directly
# in the API response (dev only, never in production).
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional: base URL used to build links in emails. Falls back to the
# request's own origin if unset — only needed behind a proxy that changes
# the origin Next.js sees.
APP_PUBLIC_URL=
